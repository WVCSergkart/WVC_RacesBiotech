<?xml version="1.0" encoding="utf-8" ?>
<Defs>

  <GeneDef ParentName="WVC_XenotypesAndGenes_GeneMorpher_Triggers" MayRequire="ludeon.rimworld.odyssey">
	<defName>WVC_MorphCondition_Space</defName>
	<label>space trigger</label>
	<description>Carriers of this gene can only morph while in a vacuum biome.</description>
	<geneClass>WVC_XenotypesAndGenes.Gene_SpaceMorph</geneClass>
	<iconPath>WVC/UI/Genes3/Gene_MorpherSubGene_SpaceTrigger</iconPath>
	<displayOrderInCategory>-60</displayOrderInCategory>
	<biostatMet>-2</biostatMet>
	<customEffectDescriptions>
		<li>Allows morph in any space (vacuum) &lt;color=#8a8ae6&gt;biome&lt;/color&gt;.</li>
	</customEffectDescriptions>
	<modExtensions>
		<li Class="WVC_XenotypesAndGenes.GeneExtension_Giver">
			<morpherTriggerGene>VacuumResistance_Total</morpherTriggerGene>
		</li>
	</modExtensions>
  </GeneDef>

  <GeneDef ParentName="WVC_XenotypesAndGenes_GeneMorpher_Triggers">
	<defName>WVC_MorphCondition_ToxBuildup</defName>
	<label>toxic trigger</label>
	<description>Carriers of this gene can only morph under severe toxin contamination.</description>
	<geneClass>WVC_XenotypesAndGenes.Gene_ToxicMorph</geneClass>
	<iconPath>WVC/UI/Genes3/Gene_MorpherSubGene_ToxTrigger</iconPath>
	<displayOrderInCategory>-60.050</displayOrderInCategory>
	<biostatMet>2</biostatMet>
	<customEffectDescriptions>
		<li>Allows morph with &lt;color=#8a8ae6&gt;toxic buildup&lt;/color&gt; 50% or higher.</li>
		<li>Morphing removes &lt;color=#8a8ae6&gt;toxic buildup&lt;/color&gt;.</li>
	</customEffectDescriptions>
	<modExtensions>
		<li Class="WVC_XenotypesAndGenes.GeneExtension_Giver">
			<morpherTriggerGene>ToxicEnvironmentResistance_Partial</morpherTriggerGene>
		</li>
	</modExtensions>
  </GeneDef>

</Defs>