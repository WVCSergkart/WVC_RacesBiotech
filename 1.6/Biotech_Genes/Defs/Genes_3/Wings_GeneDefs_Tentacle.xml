<?xml version="1.0" encoding="utf-8" ?>
<Defs>

  <GeneDef ParentName="WVC_XenotypesAndGenes_GeneWings_Psychic">
	<defName>WVC_Wings_TentacleWings</defName>
	<label>tentacle wings</label>
	<description>Carriers of this gene grow large, wing-like tentacle-like growths on their backs. With their help, the carriers can hover above the ground to a limited extent, and although the growths themselves are not real wings, flight is provided by the psychic abilities that these growths provide.</description>
	<geneClass>WVC_XenotypesAndGenes.Gene_TentacleWings</geneClass>
	<iconPath>WVC/UI/Genes3/Gene_TentacleWings</iconPath>
	<missingGeneRomanceChanceFactor>0.70</missingGeneRomanceChanceFactor>
	<capMods>
	  <li>
		<capacity>Manipulation</capacity>
		<offset>0.15</offset>
	  </li>
	</capMods>
	<renderNodeProperties>
	  <li>
		<nodeClass>WVC_XenotypesAndGenes.PawnRenderNode_Attachments</nodeClass>
		<workerClass>PawnRenderNodeWorker_AttachmentBody</workerClass>
		<texPaths>
		  <li>WVC/BodyParts/BodyParts_Wings/TentacleWings</li>
		  <li>WVC/BodyParts/BodyParts_Wings/TentacleWings1c</li>
		  <li>WVC/BodyParts/BodyParts_Wings/TentacleWings2c</li>
		</texPaths>
		<colorType>Skin</colorType>
		<overrideMeshSize>(1.0, 1.0)</overrideMeshSize>
		<parentTagDef>Body</parentTagDef>
		<rotDrawMode>Fresh, Rotting</rotDrawMode>
		<drawSize>1.5</drawSize>
		<drawData>
		  <scaleOffsetByBodySize>true</scaleOffsetByBodySize>
		  <defaultData>
			<layer>-2</layer>
		  </defaultData>
		  <dataNorth>
			<offset>(0, 0.1, -0.05)</offset>
			<layer>90</layer>
		  </dataNorth>
		  <dataSouth>
			<offset>(0, 0, -0.05)</offset>
		  </dataSouth>
		  <dataEast>
			<offset>(-0.08, 0, -0.04)</offset>
		  </dataEast>
		  <dataWest>
			<offset>(0.08, 0, -0.04)</offset>
		  </dataWest>
		</drawData>
	  </li>
	</renderNodeProperties>
	<symbolPack>
	  <prefixSymbols>
		<li><symbol>flesh</symbol></li>
		<li><symbol>abom</symbol></li>
		<li><symbol>winged</symbol></li>
		<li><symbol>wing</symbol></li>
	  </prefixSymbols>
	  <suffixSymbols>
		<li><symbol>abom</symbol></li>
		<li><symbol>flesh</symbol></li>
		<li><symbol>wing</symbol></li>
	  </suffixSymbols>
	</symbolPack>
  </GeneDef>

</Defs>