<?xml version="1.0" encoding="utf-8" ?>
<Defs>

  <!-- In Dev -->
  <GeneDef ParentName="WVC_XenotypesAndGenes_GeneAgeless_Base">
	<defName>WVC_Dustogenic_Ageless</defName>
	<label>feathered ageless</label>
	<labelShortAdj>ageless</labelShortAdj>
	<description>Carriers of this gene remain eternally young and form a special psychic connection with each other that allows them to evolve to a limited extent.</description>
	<geneClass>WVC_XenotypesAndGenes.Gene_FeatheredAgeless</geneClass>
	<iconPath>WVC/UI/Genes/Gene_AgelessAngel_v0</iconPath>
	<iconColor>(255, 255, 255)</iconColor>
	<selectionWeight>0.0012</selectionWeight>
	<displayOrderInCategory>1241</displayOrderInCategory>
	<biostatCpx>3</biostatCpx>
	<biostatArc>0</biostatArc>
	<biostatMet>-3</biostatMet>
	<!-- <selectionWeight>0</selectionWeight> -->
	<!-- <canGenerateInGeneSet>false</canGenerateInGeneSet> -->
	<customEffectDescriptions>
		<li>Decreases bio-age by 1 year every 5 days, until 18.</li>
		<li>Allows to &lt;color=#8a8ae6&gt;implant&lt;/color&gt; health related genes from a small list.</li>
		<!-- <li>Allows the pawn to &lt;color=#8a8ae6&gt;lay eggs&lt;/color&gt; instead of a live birth.</li> -->
		<li>Implantation &lt;color=#8a8ae6&gt;requires&lt;/color&gt; meeting the combined bio-chronological age requirements.</li>
		<li>All &lt;color=#8a8ae6&gt;colonists&lt;/color&gt; with this gene are used for the calculation, regardless of psy-sensitivity.</li>
		<li>Implantation of archite genes is only possible if the pawn has archite genes.</li>
	</customEffectDescriptions>
	<biologicalAgeTickFactorFromAgeCurve>
	  <points>
		<li>(13, 1)</li>
		<li>(18.5, 0)</li>
	  </points>
	</biologicalAgeTickFactorFromAgeCurve>
	<exclusionTags>
	  <li>WVC_Ageless</li>
	</exclusionTags>
	<symbolPack>
	  <prefixSymbols>
		<li><symbol>young</symbol></li>
	  </prefixSymbols>
	</symbolPack>
	<modExtensions>
		<li Class="VEF.Genes.GeneExtension" MayRequire="oskarpotocki.vanillafactionsexpanded.core">
			<hideGene>true</hideGene>
		</li>
		<li Class="WVC_XenotypesAndGenes.GeneExtension_Undead">
			<geneDefs>
			  <!-- misc -->
			  <li>WVC_Dustogenic_Blesslink</li>
			  <li>WVC_MecaBodyParts_Jaw</li>
			  <li>WVC_Dustogenic_AngelBeauty</li>
			  <li>WVC_Dustogenic_Clotting</li>
			  <li>WVC_Dustogenic_Reincarnation</li>
			  <li>WVC_Eyes_Colorful</li>
			  <li>Fertile</li>
			  <li>Superclotting</li>
			  <!-- healing -->
			  <li>WoundHealing_Fast</li>
			  <li>WoundHealing_SuperFast</li>
			  <li>WVC_WoundHealing_UnrealFast</li>
			  <li>WVC_WoundHealing_ExtremeFast</li>
			  <!-- immunity -->
			  <li>Immunity_Strong</li>
			  <li>Immunity_SuperStrong</li>
			  <!-- <li>WVC_WoundHealing_UnrealFast</li> -->
			  <!-- <li>WVC_WoundHealing_ExtremeFast</li> -->
			  <!-- reimplanters -->
			  <li>WVC_ReimplanterArchite_RiseXenogenes</li>
			  <li>WVC_ReimplanterNatural_RiseXenogenes</li>
			  <li>WVC_ReimplanterArchite_Xenogenes</li>
			  <li>WVC_ReimplanterNatural_Xenogenes</li>
			  <li>WVC_ReimplanterArchite_RiseEndogenes</li>
			  <li>WVC_ReimplanterNatural_RiseEndogenes</li>
			  <li>WVC_NaturalReimplanter_RiseFromTheDead</li>
			  <li>WVC_Reimplanter_RiseFromTheDead</li>
			  <li>WVC_NaturalReimplanter</li>
			  <li>WVC_EndogermReimplanter</li>
			  <li>WVC_Hands_Angel</li>
			  <!-- undead -->
			  <li>WVC_Undead</li>
			</geneDefs>
		</li>
	</modExtensions>
  </GeneDef>

