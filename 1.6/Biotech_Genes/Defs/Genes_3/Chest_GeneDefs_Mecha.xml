<?xml version="1.0" encoding="utf-8" ?>
<Defs>

  <GeneDef Name="WVC_XenotypesAndGenes_GeneMechaskinBasic">
	<defName>WVC_MechaSkin</defName>
	<label>metalskin</label>
	<description>Carriers of this gene have archites that completely transform the external appearance of the body, making it look like a mechanoid one.</description>
	<geneClass>WVC_XenotypesAndGenes.Gene_Bodyparts</geneClass>
	<selectionWeight>0.00125</selectionWeight>
	<biostatCpx>3</biostatCpx>
	<biostatArc>1</biostatArc>
	<iconPath>WVC/UI/Genes/Gene_FurskinD_v0</iconPath>
	<iconColor>(0.75, 0.75, 0.75)</iconColor>
	<marketValueFactor>1.5</marketValueFactor>
	<displayCategory>WVC_Cosmetic</displayCategory>
	<displayOrderInCategory>200</displayOrderInCategory>
	<!-- <fur>WVC_MechaSkin</fur> -->
	<tattoosVisible>true</tattoosVisible>
	<neverGrayHair>true</neverGrayHair>
	<!-- <customEffectDescriptions> -->
		<!-- <li>&lt;color=#8a8ae6&gt;Disables natural corpse rotting.&lt;/color&gt;</li> -->
	<!-- </customEffectDescriptions> -->
	<renderNodeProperties>
	  <li>
		<nodeClass>WVC_XenotypesAndGenes.PawnRenderNode_Bodyparts</nodeClass>
		<workerClass>PawnRenderNodeWorker_Body</workerClass>
		<baseLayer>3</baseLayer>
		<!-- <rotDrawMode>Fresh, Rotting,</rotDrawMode> -->
		<colorType>Custom</colorType>
		<parentTagDef>Body</parentTagDef>
		<overlayOverApparel>false</overlayOverApparel>
		<useSkinShader>false</useSkinShader>
		<color>(255, 255, 255)</color>
		<bodyTypeGraphicPaths>
		  <Male>WVC/Bodies/MecaGene_Body/Naked_Male</Male>
		  <Female>WVC/Bodies/MecaGene_Body/Naked_Female</Female>
		  <Hulk>WVC/Bodies/MecaGene_Body/Naked_Hulk</Hulk>
		  <Fat>WVC/Bodies/MecaGene_Body/Naked_Fat</Fat>
		  <Thin>WVC/Bodies/MecaGene_Body/Naked_Thin</Thin>
		</bodyTypeGraphicPaths>
	  </li>
	</renderNodeProperties>
	<missingGeneRomanceChanceFactor>0.75</missingGeneRomanceChanceFactor>
	<statOffsets>
	  <ComfyTemperatureMax>14</ComfyTemperatureMax>
	  <ComfyTemperatureMin>-46</ComfyTemperatureMin>
	  <ArmorRating_Blunt>0.17</ArmorRating_Blunt>
	  <ArmorRating_Sharp>0.17</ArmorRating_Sharp>
	  <ArmorRating_Heat>0.21</ArmorRating_Heat>
	  <ToxicEnvironmentResistance MayRequireAnyOf="wvc.wvcmod.wvcspecific">2.0</ToxicEnvironmentResistance>
	</statOffsets>
	<makeImmuneTo>
	  <li>MuscleParasites</li>
	</makeImmuneTo>
	<symbolPack>
	  <wholeNameSymbols>
		<li><symbol>mechanoid</symbol></li>
		<li><symbol>mechakind</symbol></li>
		<li><symbol>mecakind</symbol></li>
	  </wholeNameSymbols>
	  <prefixSymbols>
		<li><symbol>me</symbol></li>
		<li><symbol>meca</symbol></li>
		<li><symbol>mec</symbol></li>
		<li><symbol>mech</symbol></li>
		<li><symbol>mechan</symbol></li>
		<li><symbol>mach</symbol></li>
		<li><symbol>machi</symbol></li>
	  </prefixSymbols>
	  <suffixSymbols>
		<li><symbol>ine</symbol></li>
		<li><symbol>ne</symbol></li>
		<li><symbol>noid</symbol></li>
		<li><symbol>oid</symbol></li>
		<li><symbol>id</symbol></li>
	  </suffixSymbols>
	</symbolPack>
	<exclusionTags>
	  <li>WVC_ChestBodyParts_Mechaskin</li>
	  <li>WVC_ChestBodyParts_Tentacles</li>
	</exclusionTags>
	<modExtensions>
		<li Class="WVC_XenotypesAndGenes.GeneExtension_Graphic">
			<styleId>125</styleId>
		</li>
		<li Class="VEF.Genes.GeneExtension" MayRequire="oskarpotocki.vanillafactionsexpanded.core">
			<customWoundsFromFleshtype>Mechanoid</customWoundsFromFleshtype>
			<customBloodEffect>Damage_HitMechanoid</customBloodEffect>
		</li>
	</modExtensions>
  </GeneDef>

  <!-- ================================================================== -->

</Defs>