<?xml version="1.0" encoding="utf-8" ?>
<Defs>

  <GeneDef>
	<defName>WVC_Dustogenic_Clotting</defName>
	<label>downed clotting</label>
	<description>Carriers of this gene have special blood cells that, when at rest or unconscious, treat wounds and stop bleeding.</description>
	<geneClass>WVC_XenotypesAndGenes.Gene_DownedClotting</geneClass>
	<iconPath>WVC/UI/Genes/Gene_DustClotting_v0</iconPath>
	<iconColor>(0.75, 0.75, 0.75)</iconColor>
	<selectionWeight>0.0012</selectionWeight>
	<displayCategory>Healing</displayCategory>
	<displayOrderInCategory>100.001</displayOrderInCategory>
	<biostatCpx>2</biostatCpx>
	<biostatArc>0</biostatArc>
	<biostatMet>0</biostatMet>
	<customEffectDescriptions>
		<li>If a pawn is downed/sleep, its wounds will be automatically treated.</li>
		<li>Quality varies from 20% to 100%.</li>
	</customEffectDescriptions>
	<exclusionTags>
	  <li>SuperClotting</li>
	</exclusionTags>
	<symbolPack>
	  <prefixSymbols>
		<li><symbol>bleed</symbol></li>
	  </prefixSymbols>
	</symbolPack>
  </GeneDef>

