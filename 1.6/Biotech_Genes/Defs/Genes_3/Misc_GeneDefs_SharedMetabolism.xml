<?xml version="1.0" encoding="utf-8" ?>
<Defs>

  <GeneDef ParentName="WVC_XenotypesAndGenes_GeneEnergy_Base">
	<defName>WVC_SharedMetabolism</defName>
	<label>shared metabolism</label>
	<description>Carriers of this gene have archites that connect with other carriers of this gene via micro skip gates and jointly improve the carriers' metabolism.</description>
	<geneClass>WVC_XenotypesAndGenes.Gene_SharedMetabolism</geneClass>
	<iconPath>WVC/UI/Genes3/Gene_SharedMetabolism</iconPath>
	<biostatCpx>0</biostatCpx>
	<biostatArc>1</biostatArc>
	<biostatMet>0</biostatMet>
	<selectionWeight>0.00025</selectionWeight>
	<displayCategory>WVC_Miscellaneous</displayCategory>
	<displayOrderInCategory>66</displayOrderInCategory>
	<customEffectDescriptions>
		<!-- <li>The &lt;color=#8a8ae6&gt;metabolism&lt;/color&gt; of a gene depends on the number of &lt;color=#8a8ae6&gt;pawns&lt;/color&gt; with this gene.</li> -->
		<li>The &lt;color=#8a8ae6&gt;metabolism&lt;/color&gt; of this gene depends on the &lt;color=#8a8ae6&gt;total metabolism&lt;/color&gt; of pawns with this gene &lt;color=#8a8ae6&gt;divided&lt;/color&gt; by their number.</li>
	</customEffectDescriptions>
	<symbolPack>
	  <prefixSymbols>
		<li><symbol>share</symbol></li>
		<li><symbol>met</symbol></li>
	  </prefixSymbols>
	</symbolPack>
	<exclusionTags>
	  <li>WVC_SharedMetabolism</li>
	</exclusionTags>
  </GeneDef>

</Defs>