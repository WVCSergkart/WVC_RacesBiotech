<Defs>

  <GeneDef ParentName="WVC_XenotypesAndGenes_GeneImmunity_Base">
	<defName>WVC_Immunity_VeryWeak</defName>
	<label>very weak immunity</label>
	<labelShortAdj>susceptible</labelShortAdj>
	<description>Carriers of this gene gain immunity to diseases dangerously slowly than normal. They are almost guaranteed to die from infections that others would survive.</description>
	<iconPath>WVC/UI/Genes3/Gene_VeryWeakImmunity</iconPath>
	<displayOrderInCategory>-0.05</displayOrderInCategory>
	<statFactors>
	  <ImmunityGainSpeed>0.7</ImmunityGainSpeed>
	</statFactors>
	<biostatMet>4</biostatMet>
	<symbolPack>
	  <prefixSymbols>
		<li>
		  <symbol>sick</symbol>
		  <weight>3</weight>
		</li>
		<li><symbol>frail</symbol></li>
	  </prefixSymbols>
	</symbolPack>
  </GeneDef>

