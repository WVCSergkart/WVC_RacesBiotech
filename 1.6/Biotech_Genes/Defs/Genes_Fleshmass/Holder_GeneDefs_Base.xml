  <JobDef ParentName="WVC_XenotypesAndGenes_JobDef_Base">
	<defName>WVC_Holder_HoldMe</defName>
	<driverClass>WVC_XenotypesAndGenes.JobDriver_CallHolder</driverClass>
	<reportString>calling for hold.</reportString>
  </JobDef>

  <JobDef ParentName="WVC_XenotypesAndGenes_JobDef_Base">
	<defName>WVC_Holder_HoldTarget</defName>
	<driverClass>WVC_XenotypesAndGenes.JobDriver_TryHoldCaller</driverClass>
	<reportString>trying to hold.</reportString>
  </JobDef>

</Defs>