	  <Shooting>-12</Shooting>
	  <Melee>-12</Melee>
	  <!-- green 42 -->
	  <Plants>12</Plants>
	  <Cooking>6</Cooking>
	  <Animals>12</Animals>
	  <Social>12</Social>
	  <!-- base -->
	  <Medicine>6</Medicine>
