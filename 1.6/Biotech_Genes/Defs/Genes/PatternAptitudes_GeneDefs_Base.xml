<?xml version="1.0" encoding="utf-8" ?>
<Defs>

  <!-- Firmware -->

  <GeneDef ParentName="WVC_XenotypesAndGenes_Archites" Name="WVC_XenotypesAndGenes_GenePatternAptitude_Base" Abstract="True">
	<displayOrderInCategory>0</displayOrderInCategory>
	<iconColor>(255, 255, 255)</iconColor>
	<displayCategory>WVC_PatternAptitudes</displayCategory>
	<label>pattern aptitude</label>
	<labelShortAdj>pattern aptitude</labelShortAdj>
	<description>Carriers of this gene have a predetermined pattern aptitude. Pattern aptitude acts like an offset on all skills, giving significant advantages in some skills and disadvantages in others. Does not affect passion.</description>
	<iconPath>WVC/UI/Genes/Gene_AptitudesFarmer_v0</iconPath>
	<marketValueFactor>1.2</marketValueFactor>
	<biostatCpx>2</biostatCpx>
	<biostatArc>1</biostatArc>
	<biostatMet>0</biostatMet>
	<randomChosen>true</randomChosen>
	<exclusionTags>
	  <li>WVC_MechaAI_Firmware</li>
	</exclusionTags>
	<symbolPack>
	  <prefixSymbols>
		<li><symbol>patt</symbol></li>
		<li><symbol>pat</symbol></li>
		<li><symbol>apti</symbol></li>
	  </prefixSymbols>
	  <suffixSymbols>
		<li><symbol>tern</symbol></li>
		<li><symbol>ern</symbol></li>
		<li><symbol>tude</symbol></li>
	  </suffixSymbols>
	</symbolPack>
	<modExtensions>
		<li Class="WVC_XenotypesAndGenes.GeneExtension_General">
			<isAptitude>true</isAptitude>
		</li>
	</modExtensions>
  </GeneDef>

  <!-- Aptitudes -->

  <GeneDef ParentName="WVC_XenotypesAndGenes_GenePatternAptitude_Base">
	<defName>WVC_MechaAI_FirmwareCreatorMachine</defName>
	<label>pattern aptitude (creator)</label>
	<iconPath>WVC/UI/Genes3/Gene_Aptitudes_Crafter</iconPath>
	<aptitudes>
	  <!-- -30 -->
	  <!-- creator 42 -->
	  <Construction>8</Construction>
	  <Intellectual>16</Intellectual>
	  <Crafting>14</Crafting>
	  <Artistic>4</Artistic>
	  <!-- war -32 -->
	  <Mining>-16</Mining>
	  <Shooting>-10</Shooting>
	  <Melee>-6</Melee>
	  <!-- green -46 -->
	  <Plants>-10</Plants>
	  <Cooking>-6</Cooking>
	  <Animals>-14</Animals>
	  <Social>-16</Social>
	  <!-- base -->
	  <Medicine>6</Medicine>
	</aptitudes>
	<symbolPack>
	  <prefixSymbols>
		<li><symbol>crea</symbol></li>
	  </prefixSymbols>
	</symbolPack>
  </GeneDef>
  <!-- = -->
  <GeneDef ParentName="WVC_XenotypesAndGenes_GenePatternAptitude_Base">
	<defName>WVC_MechaAI_FirmwareWarMachine</defName>
	<label>pattern aptitude (war)</label>
	<iconPath>WVC/UI/Genes3/Gene_Aptitudes_War</iconPath>
	<aptitudes>
	  <!-- -30 -->
	  <!-- creator -54 -->
	  <Construction>-8</Construction>
	  <Intellectual>-16</Intellectual>
	  <Crafting>-14</Crafting>
	  <Artistic>-18</Artistic>
	  <!-- war 44 -->
	  <Mining>12</Mining>
	  <Shooting>16</Shooting>
	  <Melee>16</Melee>
	  <!-- green -26 -->
	  <Plants>-4</Plants>
	  <Cooking>-6</Cooking>
	  <Animals>-2</Animals>
	  <Social>-12</Social>
	  <!-- base -->
	  <Medicine>6</Medicine>
	</aptitudes>
	<symbolPack>
	  <prefixSymbols>
		<li><symbol>war</symbol></li>
	  </prefixSymbols>
	</symbolPack>
  </GeneDef>
  <!-- = -->
