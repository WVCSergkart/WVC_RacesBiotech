	  <Artistic>-6</Artistic>
	  <Mining>-6</Mining>
	  <Shooting>-6</Shooting>
	  <Melee>-6</Melee>
	  <Plants>-6</Plants>
	  <Cooking>-6</Cooking>
	  <Animals>-6</Animals>
	  <Social>-6</Social>
	  <Medicine>-6</Medicine>
	</aptitudes>
	<symbolPack>
	  <prefixSymbols>
		<li><symbol>shape</symbol></li>
	  </prefixSymbols>
	</symbolPack>
  </GeneDef>

</Defs>