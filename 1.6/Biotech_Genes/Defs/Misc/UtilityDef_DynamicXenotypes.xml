<?xml version="1.0" encoding="utf-8" ?>
<Defs>

  <WVC_XenotypesAndGenes.UtilityDef>
	<defName>WVC_DynamicXenotypes</defName>
	<!-- ScenPart_PawnModifier_DynamicXenotypes -->
	<xenotypeGetterDefs>
	  <li MayRequire="ludeon.rimworld.anomaly">
		<!-- anomaly_started or duplicator_obelisk -->
		<workerClass>WVC_XenotypesAndGenes.XenotypeGetter_Duplicator</workerClass>
		<chance>1.2</chance>
		<xenotypeDefs>
		  <li>WVC_RogueFormer</li>
		</xenotypeDefs>
	  </li>
	  <li MayRequire="ludeon.rimworld.anomaly">
		<!-- anomaly_endgame or nucleus or mutator_obelisk -->
		<workerClass>WVC_XenotypesAndGenes.XenotypeGetter_Fleshmass</workerClass>
		<chance>2</chance>
		<xenotypeDefs>
		  <li>WVC_Fleshkind</li>
		  <li>WVC_Overrider</li>
		</xenotypeDefs>
	  </li>
	  <li>
		<!-- gravship or (comm_console and techlevel) -->
		<workerClass>WVC_XenotypesAndGenes.XenotypeGetter_Metalkin</workerClass>
		<chance>0.2</chance>
		<xenotypeDefs>
		  <li>WVC_GeneThrower</li>
		</xenotypeDefs>
	  </li>
	  <li>
		<!-- cold_biome metalkin -->
		<workerClass>WVC_XenotypesAndGenes.XenotypeGetter_Mechakin</workerClass>
		<chance>1</chance>
		<xenotypeDefs>
		  <li>WVC_Meca</li>
		</xenotypeDefs>
	  </li>
	  <li>
		<!-- undead (any resurrected pawns) -->
		<workerClass>WVC_XenotypesAndGenes.XenotypeGetter_Undead</workerClass>
		<chance>1</chance>
		<xenotypeDefs>
		  <li>WVC_Undead</li>
		  <li>WVC_Featherdust</li>
		</xenotypeDefs>
	  </li>
	  <li>
		<!-- non-metalkin -->
		<workerClass>WVC_XenotypesAndGenes.XenotypeGetter_Tribal</workerClass>
		<chance>0.2</chance>
		<xenotypeDefs>
		  <li>WVC_RuneDryad</li>
		  <li>WVC_Golemkind</li>
		</xenotypeDefs>
	  </li>
	  <li MayRequire="ludeon.rimworld.roaylty">
		<workerClass>WVC_XenotypesAndGenes.XenotypeGetter_Faction</workerClass>
		<chance>0.7</chance>
		<factionDef>Empire</factionDef>
		<xenotypeDefs>
		  <li>WVC_Bloodeater</li>
		  <li>WVC_Lilith</li>
		</xenotypeDefs>
	  </li>
	  <li MayRequire="ludeon.rimworld.roaylty">
		<workerClass>WVC_XenotypesAndGenes.XenotypeGetter_Faction</workerClass>
		<chance>0.1</chance>
		<factionDef>Empire</factionDef>
		<xenotypeDefs>
		  <li>WVC_Ashen</li>
		  <li>WVC_Shadoweater</li>
		</xenotypeDefs>
	  </li>
	  <li MayRequire="ludeon.rimworld.anomaly">
		<workerClass>WVC_XenotypesAndGenes.XenotypeGetter_Faction</workerClass>
		<chance>0.5</chance>
		<factionDef>HoraxCult</factionDef>
		<xenotypeDefs>
		  <li>WVC_Ashen</li>
		  <li>WVC_GeneThrower</li>
		  <!-- <li>WVC_Beholdkind</li> -->
		</xenotypeDefs>
	  </li>
	  <li MayRequire="ludeon.rimworld.odyssey">
		<workerClass>WVC_XenotypesAndGenes.XenotypeGetter_Faction</workerClass>
		<chance>0.8</chance>
		<factionDef>TradersGuild</factionDef>
		<xenotypeDefs>
		  <li>WVC_Ferrkind</li>
		</xenotypeDefs>
	  </li>
	  <li>
		<!-- non-metalkin undead non-shapeshifter -->
		<workerClass>WVC_XenotypesAndGenes.XenotypeGetter_Fantasy</workerClass>
		<chance>0.2</chance>
		<xenotypeDefs>
		  <li>WVC_Reaperkind</li>
		  <li>WVC_Ripperkind</li>
		</xenotypeDefs>
	  </li>
	  <li MayRequire="ludeon.rimworld.roaylty">
		<!-- a_lot_of_vanilla_cats -->
		<workerClass>WVC_XenotypesAndGenes.XenotypeGetter_Deadcat</workerClass>
		<chance>2</chance>
		<xenotypeDefs>
		  <li>WVC_CatDeity</li>
		</xenotypeDefs>
	  </li>
	  <li>
		<!-- (fleshmass or hivemind_init) and rescueesCanJoin_faction -->
		<workerClass>WVC_XenotypesAndGenes.XenotypeGetter_Hivemind</workerClass>
		<chance>0.9</chance>
		<xenotypeDefs>
		  <li>WVC_Fleshkind</li>
		</xenotypeDefs>
	  </li>
	  <li>
		<!-- world_generation_only -->
		<workerClass>WVC_XenotypesAndGenes.XenotypeGetter_GameNotStarted</workerClass>
		<chance>5</chance>
		<xenotypeDefs>
		  <li>WVC_Mergekin</li>
		</xenotypeDefs>
	  </li>
	  <li>
		<!-- sanguophage_any_map -->
		<workerClass>WVC_XenotypesAndGenes.XenotypeGetter_Sanguophage</workerClass>
		<chance>0.1</chance>
		<xenotypeDefs>
		  <li>WVC_Bloodeater</li>
		</xenotypeDefs>
	  </li>
	  <li>
		<!-- sanguophage outdoor_temp_20+ -->
		<workerClass>WVC_XenotypesAndGenes.XenotypeGetter_Sandycat</workerClass>
		<chance>1.1</chance>
		<xenotypeDefs>
		  <li>WVC_Sandycat</li>
		</xenotypeDefs>
	  </li>
	  <li MayRequire="ludeon.rimworld.anomaly">
		<!-- defeat_mechhive and embrace_monolith -->
		<workerClass>WVC_XenotypesAndGenes.XenotypeGetter_Nociokin</workerClass>
		<chance>1.7</chance>
		<xenotypeDefs>
		  <li>WVC_Nociokin</li>
		</xenotypeDefs>
	  </li>
	  <li>
		<!-- if_any_shapeshifter -->
		<workerClass>WVC_XenotypesAndGenes.XenotypeGetter_Shapeshifter</workerClass>
		<chance>0.05</chance>
		<xenotypeDefs>
		  <li>WVC_Leper</li>
		  <li>WVC_Mechamata</li>
		</xenotypeDefs>
	  </li>
	  <li>
		<!-- if_one_man_army_mode (pawns <= 1 +- any animals and mechs) -->
		<workerClass>WVC_XenotypesAndGenes.XenotypeGetter_SoloLeveling</workerClass>
		<chance>0.5</chance>
		<!-- all mod xenotypes -->
	  </li>
	  <li>
		<!-- if_any_dryads -->
		<workerClass>WVC_XenotypesAndGenes.XenotypeGetter_Dryads</workerClass>
		<chance>1.0</chance>
		<xenotypeDefs>
		  <li>WVC_RuneDryad</li>
		</xenotypeDefs>
	  </li>
	  <li>
		<!-- if_any_xenotype -->
		<workerClass>WVC_XenotypesAndGenes.XenotypeGetter_Xenotypes</workerClass>
		<chance>0.8</chance>
		<reqXenotypeDefs>
		  <li>WVC_Mechamata</li>
		</reqXenotypeDefs>
		<xenotypeDefs>
		  <li>WVC_Fleshkind</li>
		</xenotypeDefs>
	  </li>
	</xenotypeGetterDefs>
  </WVC_XenotypesAndGenes.UtilityDef>

</Defs>
