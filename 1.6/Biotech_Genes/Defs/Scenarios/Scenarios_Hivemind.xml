  <ScenarioDef MayRequire="ludeon.rimworld.odyssey,ludeon.rimworld.ideology,ludeon.rimworld.anomaly" ParentName="ScenarioBase" WVC_EasyPatch="WVC_XaG_UniqueXenotypesScenarioDefs_Hook">
	<defName>WVC_Hivemind</defName>
	<label>Hivemind Hatred</label>
	<!-- <label>The Mindlands</label> -->
	<description>Since birth, you've heard the thoughts of others, and your thoughts have been heard by others. But now the mind is divided, and you are just one of its fragments; now you are free to decide for yourself.

&lt;color=#f5ffa2&gt;Gameplay Effects:&lt;/color&gt;\n- All pawns, regardless of faction, will be of the &lt;color=#8a8ae6&gt;random flesh-hivemind&lt;/color&gt; xenotype. Some reward pawns are an exception, as is the &lt;color=#8a8ae6&gt;Empire&lt;/color&gt; faction.\n- All surface biomes will be replaced with &lt;color=#8a8ae6&gt;grasslands&lt;/color&gt;, regardless of planetary conditions, with the exception of extreme biomes.\n- All plants fixed for the biome will have a fixed temperature range from -55C to +55C.\n- All non-player pawns will have 20 skill level.\n- All starting factions will have the &lt;color=#8a8ae6&gt;player's ideology&lt;/color&gt;.\n- A player's starting ideology will always be &lt;color=#8a8ae6&gt;fluid&lt;/color&gt;.\n- &lt;color=#8a8ae6&gt;Hivemind hatred&lt;/color&gt; offset changes from -10 to -999.\n- All &lt;color=#8a8ae6&gt;hivemind colonists&lt;/color&gt; will receive a &lt;color=#8a8ae6&gt;permanent&lt;/color&gt; hediff with -8 to all skills. Each &lt;color=#8a8ae6&gt;destroyed faction&lt;/color&gt; will add +1.\n- All non-player pawns will receive random sets of bonus genes.\n- The &lt;color=#8a8ae6&gt;non-player hivemind&lt;/color&gt; size will always be considered 50.\n- Skills do not degrade for all pawns, regardless of faction.\n- &lt;color=#8a8ae6&gt;Synchronization&lt;/color&gt; of the hivemind and awakening of the drones occurs almost immediately.\n- &lt;color=#8a8ae6&gt;Chimera&lt;/color&gt; gene &lt;color=#8a8ae6&gt;limit&lt;/color&gt; is disabled, regardless of settings.

&lt;color=#999999&gt;This scenario is a mini-mod that makes changes after it's launched. These changes are permanent for the session in which the scenario was launched.&lt;/color&gt;

&lt;color=#f5ffa2&gt;Unimposed rules:&lt;/color&gt;\n- The starting ideology must have a hivemind meme.\n- Non-hivemind pawns must be either enslaved or exiled.\n- The scenario is only considered completed once the debuff reaches 0.\n- The starting ideology must not disappear until the end of the campaign.

&lt;color=#999999&gt;All of the above conditions are not imposed by the scenario, and you are free to disregard them.&lt;/color&gt;

&lt;color=#f5ffa2&gt;Difficulty:&lt;/color&gt; This scenario is considered a hard difficulty, the starting conditions have increased requirements for the player's skill.</description>
	<!-- &lt;color=#f46d6b&gt;Warning:&lt;/color&gt; This scenario is a mini-mod that makes changes after it's launched. These changes are permanent for the session in which the scenario was launched. -->
	<scenario>
	  <!-- <summary>Two metalkins with gravship. No supplies. &lt;color=#fff695&gt;Medium&lt;/color&gt; difficulty.</summary> -->
	  <summary>One fleshkind with no supplies. &lt;color=#ff9595&gt;Veteran&lt;/color&gt; scenario.</summary>
	  <playerFaction>
		<def>PlayerFaction</def>
		<factionDef>PlayerColony</factionDef>
	  </playerFaction>
	  <parts>

		<li Class="ScenPart_ConfigPage_ConfigureStartingPawns_Xenotypes">
		  <def>ConfigurePawnsXenotypes</def>
		  <pawnChoiceCount>8</pawnChoiceCount>
		  <customSummary>Start with one fleshkind.</customSummary>
		  <overrideKinds>
			<li>
			  <xenotype>WVC_Fleshkind</xenotype>
			  <pawnKind>Mercenary_Gunner</pawnKind>
			</li>
			<!-- <li> -->
			  <!-- <xenotype>WVC_Fleshkind</xenotype> -->
			  <!-- <pawnKind>Mercenary_Gunner</pawnKind> -->
			<!-- </li> -->
		  </overrideKinds>
		  <xenotypeCounts>
			<li>
			  <xenotype>WVC_Fleshkind</xenotype>
			  <count>1</count>
			  <description>non-baby fleshkind</description>
			  <requiredAtStart>true</requiredAtStart>
			  <allowedDevelopmentalStages>Adult, Child</allowedDevelopmentalStages>
			</li>
		  </xenotypeCounts>
		</li>

		<!-- Player starting stuff spawn method-->
		<li Class="ScenPart_PlayerPawnsArriveMethod">
		  <def>PlayerPawnsArriveMethod</def>
		  <method>Standing</method>
		</li>

		<!-- Game start dialog -->
		<li Class="ScenPart_GameStartDialog">
		  <def>GameStartDialog</def>
		  <text>Since birth, you've heard the thoughts of others, and your thoughts have been heard by others. But now the mind is divided, and you are just one of its fragments; now you are free to decide for yourself.</text>
		  <closeSound>GameStartSting</closeSound>
		</li>

		<!-- Player pawns start with no possessions eg. extra drugs. -->
		<li Class="ScenPart_NoPossessions">
		  <def>NoPossessions</def>
		</li>

		<!-- Player pawns modifiers -->
		<li Class="WVC_XenotypesAndGenes.ScenPart_PawnModifier_XenotypesAndGenes">
		  <def>WVC_XaG_Starting</def>
		  <!-- <startingDuplicates>2</startingDuplicates> -->
		  <additionalChronoAge>70~120</additionalChronoAge>
		  <context>PlayerStarter</context>
		  <geneDefs>
			<li>WVC_Duplicator_ZeroOutChance</li>
		  </geneDefs>
		</li>

		<!-- Forced world and xenotypes -->
		<li Class="WVC_XenotypesAndGenes.ScenPart_HivemindWorld">
		  <def>WVC_XaG_Starting</def>
		  <context>NonPlayer</context>
		  <biomeDef>Grasslands</biomeDef>
		  <!-- any hediffDef -->
		  <hediffDef>WVC_HivemindHatred</hediffDef>
		  <hivemindHatred>WVC_HivemindHatred</hivemindHatred>
		  <hivemindPresets>
			<li>
			  <selectionWeight>0.95</selectionWeight>
			  <geneDefs>
				<li>WVC_Tough</li>
				<li>WVC_MechaPowerSource_Vanometric</li>
				<!-- <li>ArchiteMetabolism</li> -->
				<!-- <li>WVC_Hivemind_DeathChain</li> -->
				<!-- <li>Deathless</li> -->
			  </geneDefs>
			</li>
			<li>
			  <selectionWeight>0.44</selectionWeight>
			  <geneDefs>
				<li>WVC_Tough</li>
				<li>WVC_MechaPowerSource_Vanometric</li>
				<li>ArchiteMetabolism</li>
				<li>WVC_Hivemind_Regeneration</li>
				<!-- <li>Deathless</li> -->
			  </geneDefs>
			</li>
			<li>
			  <selectionWeight>0.66</selectionWeight>
			  <geneDefs>
				<li>WVC_Tough</li>
				<!-- <li>WVC_MechaPowerSource_Vanometric</li> -->
				<!-- <li>ArchiteMetabolism</li> -->
				<li>WVC_Hivemind_Regeneration</li>
				<!-- <li>Deathless</li> -->
				<li>WVC_NoLearning</li>
			  </geneDefs>
			</li>
			<li>
			  <selectionWeight>0.38</selectionWeight>
			  <geneDefs>
				<li>WVC_Unbreakable</li>
				<!-- <li>WVC_MechaPowerSource_Vanometric</li> -->
				<li>ArchiteMetabolism</li>
				<!-- <li>WVC_Hivemind_DeathChain</li> -->
				<!-- <li>Deathless</li> -->
			  </geneDefs>
			</li>
			<li>
			  <selectionWeight>0.05</selectionWeight>
			  <geneDefs>
				<li>WVC_GrayGooSkin</li>
				<li>WVC_MechaPowerSource_Vanometric</li>
				<li>ArchiteMetabolism</li>
				<li>WVC_Hivemind_DeathChain</li>
				<li>Deathless</li>
			  </geneDefs>
			</li>
			<li>
			  <selectionWeight>0.2</selectionWeight>
			  <geneDefs>
				<li>WVC_Hivemind_Mood</li>
				<li>WVC_PsychicAbility_Hivemind</li>
				<li>WVC_Hivemind_SyncNode</li>
			  </geneDefs>
			</li>
			<li>
			  <selectionWeight>0.2</selectionWeight>
			  <geneDefs>
				<li>WVC_Hivemind_Telepathy</li>
				<li MayRequire="ludeon.rimworld.ideology">WVC_Hivemind_IdeoSync</li>
			  </geneDefs>
			</li>
			<li>
			  <selectionWeight>0.3</selectionWeight>
			  <geneDefs>
				<li>WVC_HiveMind_Needs</li>
				<li>WVC_HiveMind_Skills</li>
				<li>WVC_Hivemind_DeathChain</li>
				<li>Deathless</li>
			  </geneDefs>
			</li>
		  </hivemindPresets>
		  <xenotypeDefs>
			<li>WVC_Fleshkind</li>
			<li MayRequire="ludeon.rimworld.anomaly">WVC_Overrider</li>
		  </xenotypeDefs>
		</li>

		<!-- <li Class="ScenPart_StartingThing_Defined"> -->
