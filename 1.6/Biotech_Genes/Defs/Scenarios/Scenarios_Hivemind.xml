  <HediffDef MayRequire="ludeon.rimworld.odyssey,ludeon.rimworld.ideology,ludeon.rimworld.anomaly" ParentName="WVC_XenotypesAndGenes_Hediffs_OneTime">
	<defName>WVC_HivemindHatred</defName>
	<label>hivemind hatred</label>
	<description>The psychic influence of a more powerful hivemind suppresses the owner's abilities.</description>
	<defaultLabelColor>(0.9, 1.0, 0.35)</defaultLabelColor>
	<aptitudes>
	  <Intellectual>-8</Intellectual>
	  <Social>-8</Social>
	  <Medicine>-8</Medicine>
	  <Artistic>-8</Artistic>
	  <Crafting>-8</Crafting>
	  <Animals>-8</Animals>
	  <Plants>-8</Plants>
	  <Cooking>-8</Cooking>
	  <Mining>-8</Mining>
	  <Construction>-8</Construction>
	  <Melee>-8</Melee>
	  <Shooting>-8</Shooting>
	</aptitudes>
  </HediffDef>

