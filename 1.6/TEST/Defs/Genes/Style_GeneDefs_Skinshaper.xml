  <GeneDef>
	<defName>WVC_Skinshaper</defName>
	<label>skinshaper</label>
	<description>Carriers of this gene can change certain aspects of their appearance at will at any time.</description>
	<geneClass>WVC_XenotypesAndGenes.Gene_Skinshaper</geneClass>
	<iconPath>WVC/UI/Genes/Gene_Style</iconPath>
	<iconColor>(0.75, 0.75, 0.75)</iconColor>
	<selectionWeight>0.0012</selectionWeight>
	<displayCategory>WVC_Cosmetic</displayCategory>
	<displayOrderInCategory>2</displayOrderInCategory>
	<customEffectDescriptions>
		<li>Allows to switch sets of pre-prepared genes.</li>
		<li>Each set is a set of a furskin or head and skin/hair color.</li>
	</customEffectDescriptions>
	<biostatCpx>1</biostatCpx>
	<biostatArc>1</biostatArc>
	<biostatMet>0</biostatMet>
  </GeneDef>

