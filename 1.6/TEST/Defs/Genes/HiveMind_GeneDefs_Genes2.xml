  <GeneDef ParentName="WVC_XenotypesAndGenes_GeneHivemind_Base">
	<defName>WVC_Hivemind_Metabolism</defName>
	<label>hivemind metabolism</label>
	<description>Carriers of this gene have archites that improve overall metabolism relative to hivemind size.</description>
	<geneClass>WVC_XenotypesAndGenes.Gene_Hivemind_Metabolism</geneClass>
	<iconPath>WVC/UI/Genes3/Gene_Hivemind_Metabolism</iconPath>
	<displayOrderInCategory>110</displayOrderInCategory>
	<biostatCpx>5</biostatCpx>
	<biostatArc>3</biostatArc>
	<biostatMet>0</biostatMet>
	<customEffectDescriptions>
		<li>Gene &lt;color=#8a8ae6&gt;metabolism&lt;/color&gt; varies with &lt;color=#8a8ae6&gt;hivemind size&lt;/color&gt;.</li>
	</customEffectDescriptions>
	<exclusionTags>
	  <li>WVC_SharedMetabolism</li>
	</exclusionTags>
  </GeneDef>

