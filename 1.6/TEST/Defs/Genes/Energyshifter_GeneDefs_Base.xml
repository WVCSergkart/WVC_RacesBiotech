<?xml version="1.0" encoding="utf-8" ?>
<Defs>

  <GeneDef ParentName="WVC_XenotypesAndGenes_GeneShapeshifter_MainGene">
	<defName>WVC_Energyshifter</defName>
	<label>energyshifter</label>
	<description>Carriers of this gene have archites that are capable of rewriting and editing their owners' genetic code within certain limits, using the body's nutrients as energy.</description>
	<geneClass>WVC_XenotypesAndGenes.Gene_Energyshifter</geneClass>
	<iconPath>WVC/UI/Genes3/Gene_Energyshifter</iconPath>
	<resourceGizmoType>WVC_XenotypesAndGenes.GeneGizmo_Energyshifter</resourceGizmoType>
	<displayOrderInCategory>1</displayOrderInCategory>
	<biostatCpx>2</biostatCpx>
	<customEffectDescriptions>
		<li>&lt;color=#8a8ae6&gt;Consumes nutrients&lt;/color&gt; as a % of maximum. Dependent on active &lt;color=#8a8ae6&gt;subgenes&lt;/color&gt;.</li>
		<li>Allows to turn &lt;color=#8a8ae6&gt;subgenes&lt;/color&gt; on and off.</li>
	</customEffectDescriptions>
	<exclusionTags>
	  <li>WVC_Energyshifter</li>
	  <li>WVC_XaG_EternalHunger</li>
	</exclusionTags>
	<modExtensions>
		<li Class="WVC_XenotypesAndGenes.GeneExtension_Giver">
			<xenotypeDefs>
			  <li>WVC_GeneThrower</li>
			  <li>WVC_Ferrkind</li>
			  <li>WVC_Rustkind</li>
			</xenotypeDefs>
		</li>
	</modExtensions>
  </GeneDef>

  <GeneDef ParentName="WVC_XenotypesAndGenes_GeneShapeshifter_Base" Name="WVC_XenotypesAndGenes_GeneEnergyshifter_SubGenes" Abstract="True">
	<geneClass>WVC_XenotypesAndGenes.Gene_Energyshifter_SubGene</geneClass>
	<biostatCpx>3</biostatCpx>
	<biostatArc>3</biostatArc>
	<biostatMet>0</biostatMet>
	<selectionWeight>0.00</selectionWeight>
	<canGenerateInGeneSet>false</canGenerateInGeneSet>
	<displayOrderInCategory>200</displayOrderInCategory>
	<prerequisite>WVC_Energyshifter</prerequisite>
	<minAgeActive>0</minAgeActive>
	<resourceLossPerDay>0.10</resourceLossPerDay>
  </GeneDef>

</Defs>