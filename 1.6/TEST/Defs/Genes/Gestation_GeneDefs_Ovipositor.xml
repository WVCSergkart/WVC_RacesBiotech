<?xml version="1.0" encoding="utf-8" ?>
<Defs>

  <GeneDef>
	<defName>WVC_Ovipositor</defName>
	<label>ovipositor</label>
	<description>Carriers of this gene lay eggs instead of giving live birth. Eggs need time and correct conditions to hatch.</description>
	<geneClass>WVC_XenotypesAndGenes.Gene_Ovipositor</geneClass>
	<iconPath>WVC/UI/Genes3/Gene_Ovipositor</iconPath>
	<displayCategory>Reproduction</displayCategory>
	<displayOrderInCategory>105</displayOrderInCategory>
	<iconColor>(0.75, 0.75, 0.75)</iconColor>
	<biostatCpx>2</biostatCpx>
	<biostatMet>-1</biostatMet>
	<customEffectDescriptions>
		<!-- <li>Gene &lt;color=#8a8ae6&gt;metabolism&lt;/color&gt; varies with &lt;color=#8a8ae6&gt;hivemind size&lt;/color&gt;.</li> -->
		<!-- <li>Lays eggs instead of pregnancy and live birth.</li> -->
		<!-- <li>Laying eggs makes the pawn temporarily infertile.</li> -->
		<li>Allows the pawn to &lt;color=#8a8ae6&gt;lay eggs&lt;/color&gt; instead of a live birth.</li>
		<li>An egg can be laid 3 days after the &lt;color=#8a8ae6&gt;pregnancy&lt;/color&gt; begins.</li>
		<li>If the pawn does not &lt;color=#8a8ae6&gt;lay&lt;/color&gt; an egg within 5 days, the &lt;color=#8a8ae6&gt;pregnancy&lt;/color&gt; will proceed as normal.</li>
		<li>Destroying the egg counts as &lt;color=#8a8ae6&gt;miscarriage&lt;/color&gt;.</li>
		<li>The pawn will attempt to lay the egg in a safe location.</li>
		<!-- later -->
		<!-- <li>Eating the egg does not count as cannibalism until 60% progress has been reached.</li> -->
	</customEffectDescriptions>
	<symbolPack>
		<wholeNameSymbols>
			<li>
				<symbol>egglayer</symbol>
			</li>
			<li>
				<symbol>oviparous</symbol>
			</li>
			<li>
				<symbol>ovipositor</symbol>
			</li>
			<li>
				<symbol>egger</symbol>
			</li>
			<li>
				<symbol>hatcher</symbol>
			</li>
		</wholeNameSymbols>
		<prefixSymbols>
			<li>
				<symbol>egg</symbol>
			</li>
			<li>
				<symbol>bud</symbol>
			</li>
			<li>
				<symbol>roe</symbol>
			</li>
		</prefixSymbols>
		<suffixSymbols>
			<li>
				<symbol>layer</symbol>
			</li>
			<li>
				<symbol>parous</symbol>
			</li>
			<li>
				<symbol>positor</symbol>
			</li>
		</suffixSymbols>
	</symbolPack>
	<exclusionTags>
	  <li>Egglaying</li>
	</exclusionTags>
	<modExtensions>
		<li Class="WVC_XenotypesAndGenes.GeneExtension_Spawner">
			<thingDefToSpawn>WVC_EggHumanFertilized</thingDefToSpawn>
			<jobDef>WVC_LayHumanEgg</jobDef>
			<showMessageIfOwned>true</showMessageIfOwned>
			<spawnMessage>WVC_HumanEggLay</spawnMessage>
			<cooldownHediffDef>WVC_Ovipositor_LayedEgg</cooldownHediffDef>
		</li>
	</modExtensions>
  </GeneDef>

  <HediffDef ParentName="WVC_XenotypesAndGenes_Hediffs_OneTime">
	<defName>WVC_Ovipositor_LayedEgg</defName>
	<label>post lay recovery</label>
	<description>The carrier's body recovers after the egg is laid. This will take some time and will be accompanied by pain.</description>
	<hediffClass>HediffWithComps</hediffClass>
	<preventsPregnancy>true</preventsPregnancy>
	<stages>
	  <li>
		<painOffset>0.12</painOffset>
		<!-- <hungerRateFactorOffset>0.2</hungerRateFactorOffset> -->
		<capMods>
		  <li>
			<capacity>Moving</capacity>
			<offset>-0.1</offset>
		  </li>
		</capMods>
	  </li>
	</stages>
	<comps>
		<li Class="HediffCompProperties_Disappears">
			<disappearsAfterTicks>60000~62000</disappearsAfterTicks>
			<showRemainingTime>true</showRemainingTime>
		</li>
	</comps>
  </HediffDef>

  <ThingDef ParentName="EggFertBase">
	<defName>WVC_EggHumanFertilized</defName>
	<label>human egg (fert.)</label>
	<description>A fertilized human egg. If all goes well, it should hatch into a human. It can be eaten raw, but it's much, much better cooked. For the first 9 days, this doesn't count as murder, but it will upset the owners.</description>
	 <!-- For the first 9 days, this isn't considered cannibalism, but it will upset the egg's owners. -->
	<!-- <possessionCount>1</possessionCount> -->
	<ingestible>
	  <!-- <ateEvent>AteHumanMeat</ateEvent> -->
	  <!-- very rare -->
	  <optimalityOffsetHumanlikes>-99999</optimalityOffsetHumanlikes>
	  <optimalityOffsetFeedingAnimals>-999</optimalityOffsetFeedingAnimals>
	  <outcomeDoers>
		<li Class="WVC_XenotypesAndGenes.IngestionOutcomeDoer_HumanEgg" >
		  <thoughtDef>WVC_AteMyEgg</thoughtDef>
		</li>
	  </outcomeDoers>
	</ingestible>
	<graphicData>
	  <texPath>WVC/Things/XaG_Items/HumanEgg</texPath>
	  <color>(245,245,245)</color>
	  <drawSize>1.0</drawSize>
	</graphicData>
	<statBases>
	  <MaxHitPoints>50</MaxHitPoints>
	  <MarketValue>30.0</MarketValue>
	  <Nutrition>1</Nutrition>
	  <FoodPoisonChanceFixedHuman>0.05</FoodPoisonChanceFixedHuman>
	</statBases>
	<comps>
	  <li Class="WVC_XenotypesAndGenes.CompProperties_HumanEgg">
		<!-- auto hatch time -->
		<hatcherDaystoHatch>-1</hatcherDaystoHatch>
		<!-- <hatcherPawn>Chicken</hatcherPawn> -->
	  </li>
	  <!-- <li Class="CompProperties_Ingredients" /> -->
	</comps>
  </ThingDef>

  <JobDef>
	<defName>WVC_LayHumanEgg</defName>
	<driverClass>WVC_XenotypesAndGenes.JobDriver_LayHumanEgg</driverClass>
	<reportString>laying egg.</reportString>
	<casualInterruptible>false</casualInterruptible>
	<allowOpportunisticPrefix>true</allowOpportunisticPrefix>
  </JobDef>

  <ThoughtDef>
	<defName>WVC_AteMyEgg</defName>
	<thoughtClass>Thought_MemorySocial</thoughtClass>
	<validWhileDespawned>true</validWhileDespawned>
	<durationDays>5</durationDays>
	<stages>
	  <li>
		<label>ate my egg</label>
		<baseOpinionOffset>-5</baseOpinionOffset>
	  </li>
	</stages>
  </ThoughtDef>

</Defs>