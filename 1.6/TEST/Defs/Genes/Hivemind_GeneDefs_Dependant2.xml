<?xml version="1.0" encoding="utf-8" ?>
<Defs>

  <GeneDef ParentName="WVC_XenotypesAndGenes_GeneHivemind_Dependant">
	<defName>WVC_Hivemind_DormantImmunity</defName>
	<label>dormant immunity</label>
	<description>Carriers of this gene have an immune system that draws information about diseases from other hivemind drones. The larger the hivemind, the more effective the immune system.</description>
	<geneClass>WVC_XenotypesAndGenes.Gene_Hivemind_Dependant</geneClass>
	<!-- <iconPath>WVC/UI/Genes3/Gene_Dormant_Immunity</iconPath> -->
	<displayOrderInCategory>-80</displayOrderInCategory>
	<biostatCpx>1</biostatCpx>
	<biostatMet>-2</biostatMet>
	<conditionalStatAffecters>
	  <li Class="WVC_XenotypesAndGenes.ConditionalStatAffecter_HivemindSize">
		<size>2</size>
		<statOffsets>
		  <ImmunityGainSpeed>0.05</ImmunityGainSpeed>
		</statOffsets>
	  </li>
	  <li Class="WVC_XenotypesAndGenes.ConditionalStatAffecter_HivemindSize">
		<size>4</size>
		<statOffsets>
		  <ImmunityGainSpeed>0.05</ImmunityGainSpeed>
		</statOffsets>
	  </li>
	  <li Class="WVC_XenotypesAndGenes.ConditionalStatAffecter_HivemindSize">
		<size>8</size>
		<statOffsets>
		  <ImmunityGainSpeed>0.10</ImmunityGainSpeed>
		</statOffsets>
	  </li>
	</conditionalStatAffecters>
	<exclusionTags>
	  <li>Immunity</li>
	</exclusionTags>
  </GeneDef>

  <!-- ========================= -->

  <GeneDef ParentName="WVC_XenotypesAndGenes_GeneHivemind_Dependant">
	<defName>WVC_Hivemind_DormantHealing</defName>
	<label>dormant wound healing</label>
	<description>Carriers of this gene heal from wounds faster the larger their hivemind.</description>
	<geneClass>WVC_XenotypesAndGenes.Gene_Hivemind_Dependant</geneClass>
	<!-- <iconPath>WVC/UI/Genes3/Gene_Dormant_Heal</iconPath> -->
	<displayOrderInCategory>-75</displayOrderInCategory>
	<biostatCpx>1</biostatCpx>
	<biostatMet>-2</biostatMet>
	<conditionalStatAffecters>
	  <li Class="WVC_XenotypesAndGenes.ConditionalStatAffecter_HivemindSize">
		<size>2</size>
		<statOffsets>
		  <InjuryHealingFactor>0.25</InjuryHealingFactor>
		</statOffsets>
	  </li>
	  <li Class="WVC_XenotypesAndGenes.ConditionalStatAffecter_HivemindSize">
		<size>4</size>
		<statOffsets>
		  <InjuryHealingFactor>0.25</InjuryHealingFactor>
		</statOffsets>
	  </li>
	  <li Class="WVC_XenotypesAndGenes.ConditionalStatAffecter_HivemindSize">
		<size>8</size>
		<statOffsets>
		  <InjuryHealingFactor>0.25</InjuryHealingFactor>
		</statOffsets>
	  </li>
	</conditionalStatAffecters>
	<exclusionTags>
	  <li>WoundHealingRate</li>
	</exclusionTags>
  </GeneDef>

</Defs>