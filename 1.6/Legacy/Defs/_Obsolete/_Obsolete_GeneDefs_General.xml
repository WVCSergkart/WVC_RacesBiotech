  <GeneDef>
	<defName>WVC_DisabledAllWork_Blank</defName>
	<label>blank memory</label>
	<description>Carriers of this gene very quickly lose interest and forget skills.</description>
	<geneClass>WVC_XenotypesAndGenes.Gene_Blank</geneClass>
	<displayCategory>Miscellaneous</displayCategory>
	<displayOrderInCategory>29.02</displayOrderInCategory>
	<iconPath>WVC/UI/Genes/Gene_Blankind_v0</iconPath>
	<biostatCpx>1</biostatCpx>
	<biostatArc>0</biostatArc>
	<biostatMet>6</biostatMet>
	<customEffectDescriptions>
	  <li>&lt;color=#ff8585&gt;Skills, regardless of level, lose exp.&lt;/color&gt;</li>
	</customEffectDescriptions>
	<selectionWeight>0</selectionWeight>
	<canGenerateInGeneSet>false</canGenerateInGeneSet>
	<exclusionTags>
	  <li>WVC_ExcellentMemory</li>
	</exclusionTags>
	<symbolPack>
	  <prefixSymbols>
		<li><symbol>use</symbol></li>
	  </prefixSymbols>
	  <suffixSymbols>
		<li><symbol>less</symbol></li>
	  </suffixSymbols>
	</symbolPack>
	<modExtensions>
		<li Class="VEF.Genes.GeneExtension" MayRequire="oskarpotocki.vanillafactionsexpanded.core">
			<hideGene>true</hideGene>
		</li>
		<li Class="WVC_XenotypesAndGenes.GeneExtension_Obsolete"/>
	</modExtensions>
  </GeneDef>

